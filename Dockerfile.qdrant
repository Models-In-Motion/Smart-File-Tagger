FROM python:3.11-slim

WORKDIR /app

# Heavy Python deps: sentence-transformers pulls torch (~1.5GB)
COPY requirements-qdrant.txt .
RUN pip install --no-cache-dir -r requirements-qdrant.txt

# Only the script that needs these deps
COPY qdrant_demo.py .

ENTRYPOINT ["python", "qdrant_demo.py"]
CMD ["--help"]
